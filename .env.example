# OpenAI API Configuration
# Copy this file and rename to .env (remove .example)
# Then add your actual API key below

OPENAI_API_KEY=your-api-key-here

# Instructions:
# 1. Replace 'your-api-key-here' with your actual OpenAI API key
# 2. Your API key should start with 'sk-'
# 3. Never commit this file to Git (it's in .gitignore)
# 4. Keep this file secure and private

# Example (DO NOT USE THIS - GET YOUR OWN KEY):
# OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
